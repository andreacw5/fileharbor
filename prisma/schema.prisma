// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Multi-tenant Client
model Client {
  id             String   @id @default(uuid())
  name           String
  apiKey         String   @unique
  domain         String?  @unique
  active         Boolean  @default(true)
  webhookEnabled Boolean  @default(false)
  webhookUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Tinify credentials (optional, can be set per client for image optimization)
  tinifyActive       Boolean @default(false)
  tinifyApiKey       String?
  currentTinifyUsage Int     @default(0) // Track current month's usage for billing purposes
  currentTinifyLimit Int     @default(500) // Monthly compression limit (default: 500 for free tier)

  // Relations
  users   User[]
  images  Image[]
  avatars Avatar[]
  albums  Album[]
  tags    Tag[]
  videos  Video[]

  @@map("clients")
}

// User within a client
model User {
  id             String  @id @default(uuid())
  clientId       String
  externalUserId String // ID from client's application
  email          String?
  username       String?

  website String?
  bio     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  images         Image[]
  videos         Video[]
  avatars        Avatar[]
  albums         Album[]
  adminBookmarks AdminUserBookmark[]

  @@unique([clientId, externalUserId])
  @@index([clientId])
  @@index([externalUserId])
  @@map("users")
}

// Image entity
model Image {
  id              String    @id @default(uuid())
  clientId        String
  userId          String
  originalName    String
  storagePath     String // e.g., storage/domain/images/{imageId}
  format          String // webp, jpeg, png
  width           Int
  height          Int
  size            Int // bytes
  mimeType        String
  isOptimized     Boolean   @default(false)
  optimizedAt     DateTime?
  tinifyOptimized Boolean   @default(false) // Track if image was compressed with Tinify to avoid reprocessing
  isPrivate       Boolean   @default(false)
  views           Int       @default(0)
  downloads       Int       @default(0)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  client          Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumImages     AlbumImage[]
  imageTags       ImageTag[]
  shareLinks      ImageShareLink[]
  albumCoverImage Album[]              @relation("AlbumCoverImage")
  adminBookmarks  AdminImageBookmark[]

  @@index([clientId])
  @@index([userId])
  @@index([isOptimized])
  @@index([isPrivate])
  @@map("images")
}

// Client-scoped tag entity
model Tag {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  imageTags ImageTag[]
  videoTags VideoTag[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([name])
  @@map("tags")
}

// Many-to-many relationship between Image and Tag
model ImageTag {
  imageId   String
  tagId     String
  createdAt DateTime @default(now())

  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([imageId, tagId])
  @@index([tagId])
  @@map("image_tags")
}

// Video entity
model Video {
  id           String   @id @default(uuid())
  clientId     String
  userId       String
  originalName String
  storagePath  String
  mimeType     String
  size         Int
  duration     Float?
  width        Int?
  height       Int?
  isPrivate    Boolean  @default(false)
  views        Int      @default(0)
  downloads    Int      @default(0)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client         Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTags      VideoTag[]
  adminBookmarks AdminVideoBookmark[]

  @@index([clientId])
  @@index([userId])
  @@index([clientId, userId])
  @@index([isPrivate])
  @@map("videos")
}

// Many-to-many relationship between Video and Tag
model VideoTag {
  videoId   String
  tagId     String
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([videoId, tagId])
  @@index([tagId])
  @@map("video_tags")
}

// Admin personal bookmark for a video
model AdminVideoBookmark {
  id          String   @id @default(uuid())
  adminUserId String
  videoId     String
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, videoId])
  @@index([adminUserId])
  @@index([videoId])
  @@map("admin_video_bookmarks")
}

// Avatar entity - one active per user per client
model Avatar {
  id          String    @id @default(uuid())
  clientId    String
  userId      String
  storagePath String // e.g., storage/domain/avatars/{userId}
  format      String
  width       Int
  height      Int
  size        Int
  mimeType    String
  isOptimized Boolean   @default(false)
  optimizedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId]) // Only one active avatar per user
  @@index([clientId])
  @@index([userId])
  @@map("avatars")
}

// Album entity
model Album {
  id              String   @id @default(uuid())
  clientId        String
  userId          String
  externalAlbumId String? // ID from client's application
  name            String
  description     String?
  isPublic        Boolean  @default(false)
  coverImageId    String? // Reference to the cover image
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverImage  Image?       @relation("AlbumCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  albumImages AlbumImage[]
  albumTokens AlbumToken[]

  @@unique([clientId, externalAlbumId])
  @@index([clientId])
  @@index([userId])
  @@index([isPublic])
  @@index([coverImageId])
  @@map("albums")
}

// Many-to-many relationship between Album and Image
model AlbumImage {
  id        String   @id @default(uuid())
  albumId   String
  imageId   String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([albumId, imageId])
  @@index([albumId])
  @@index([imageId])
  @@map("album_images")
}

// Token for private album access
model AlbumToken {
  id        String    @id @default(uuid())
  albumId   String
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  // Relations
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([token])
  @@map("album_tokens")
}

// Admin user for the management GUI
model AdminUser {
  id               String    @id @default(uuid())
  bastionUserId    String    @unique // ID from Bastion's authentication system
  email            String    @unique
  username         String?
  image            String?
  active           Boolean   @default(true)
  allClientsAccess Boolean   @default(false) // if true, can access all clients
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  clientAccess   AdminClientAccess[]
  bookmarks      AdminImageBookmark[]
  userBookmarks  AdminUserBookmark[]
  videoBookmarks AdminVideoBookmark[]

  @@index([email])
  @@map("admin_users")
}

// Allowed clients for an admin user (used when allClientsAccess = false)
model AdminClientAccess {
  id          String   @id @default(uuid())
  adminUserId String
  clientId    String
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, clientId])
  @@index([adminUserId])
  @@index([clientId])
  @@map("admin_client_access")
}

// Admin personal bookmark for an image
model AdminImageBookmark {
  id          String   @id @default(uuid())
  adminUserId String
  imageId     String
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  image     Image     @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, imageId])
  @@index([adminUserId])
  @@index([imageId])
  @@map("admin_image_bookmarks")
}

// Admin personal bookmark for a user
model AdminUserBookmark {
  id          String   @id @default(uuid())
  adminUserId String
  userId      String
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, userId])
  @@index([adminUserId])
  @@index([userId])
  @@map("admin_user_bookmarks")
}

// Cache of Bastion user profile data, keyed by JWT sub
model UserCache {
  id        String   @id // = sub from Bastion JWT, set explicitly
  username  String?
  email     String?
  image     String?
  updatedAt DateTime @updatedAt

  @@map("user_cache")
}

// Token for private image sharing
model ImageShareLink {
  id        String    @id @default(uuid())
  imageId   String
  readToken String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  // Relations
  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([readToken])
  @@map("image_share_links")
}
